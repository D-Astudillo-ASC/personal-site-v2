{
  "name": "personal-site-v2",
  "version": "0.1.0",
  "private": true,
  "author": "Daniel Astudillo",
  "description": "Daniel Astudillo's personal site",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "postbuild": "cp -r public .next/standalone/ && cp -r .next/static .next/standalone/.next/",
    "start": "node .next/standalone/server.js",
    "lint": "eslint . --fix",
    "format": "prettier --write **/*.{ts,tsx,css,mjs}",
    "format:check": "prettier --check **/*.{ts,tsx,css,mjs}",
    "analyze": "ANALYZE=true next build",
    "security:shai-hulud": "bash scripts/shai-hulud-scan.sh",
    "security:shai-hulud:clean": "CLEAN_NEXT=1 bash scripts/shai-hulud-scan.sh",
    "security:shai-hulud:paranoid": "bash scripts/shai-hulud-scan.sh --paranoid"
  },
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/react-fontawesome": "^3.3.1",
    "@mdx-js/loader": "^3.1.1",
    "@next/mdx": "16.3.0-canary.44",
    "@tailwindcss/typography": "^0.5.19",
    "@types/nodemailer": "^8.0.0",
    "framer-motion": "^12.40.0",
    "github-slugger": "^2.0.0",
    "next": "16.3.0-canary.44",
    "next-themes": "^0.4.6",
    "nodemailer": "^8.0.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "shiki": "^4.1.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@next/bundle-analyzer": "16.3.0-canary.44",
    "@next/eslint-plugin-next": "16.3.0-canary.44",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.0",
    "eslint": "10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Edge versions",
    "last 2 Safari versions"
  ],
  "packageManager": "pnpm@11.1.1"
}
